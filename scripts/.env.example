# ============================================
# KRISTO TRAVEL INTELLIGENCE API - Environment
# Копирай този файл като .env и попълни стойностите
# ============================================

# (ЗАДЪЛЖИТЕЛНО) Твоят Base мрежа портфейл адрес
WALLET_ADDRESS=0xYourBaseWalletAddressHere

# (Опционално) Собствен Base RPC (по-бърз, с rate limits)
BASE_RPC_URL=https://mainnet.base.org

# Цена на заявка в USDC
PRICE_USDC=0.25

# Порт (по подразбиране 8000)
PORT=8000